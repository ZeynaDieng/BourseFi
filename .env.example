DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# PayTech (passerelle de paiement)
# Clés disponibles sur le dashboard PayTech (Paramètres > API)
PAYTECH_API_KEY=""
PAYTECH_API_SECRET=""
# "test" (sandbox) ou "prod" (compte activé requis)
PAYTECH_ENV="test"

# URL publique du site (HTTPS) utilisée pour construire les callbacks PayTech (ipn/success/cancel)
NUXT_PUBLIC_SITE_URL="https://boursefi.sn"

# Emails transactionnels — Brevo
# Option 1 (recommandée) : clé API HTTP (Brevo > SMTP & API > Clés API)
# NUXT_BREVO_API_KEY est lu au runtime en prod (PM2) ; BREVO_API_KEY aussi.
NUXT_BREVO_API_KEY=""
BREVO_API_KEY=""
# Option 2 (fallback) : SMTP (Brevo > SMTP & API > SMTP)
SMTP_HOST="smtp-relay.brevo.com"
SMTP_PORT="587"
SMTP_USER="xxxxxx@smtp-brevo.com"
SMTP_PASS=""
# Adresse expéditrice (doit être un expéditeur vérifié dans Brevo)
EMAIL_FROM="no-reply@boursefi.sn"
EMAIL_FROM_NAME="BourseFi"
# NB : Brevo > Sécurité > IP autorisées doit inclure l'IP du serveur (ou désactiver la restriction)

# Fichiers uploadés (CNI, attestations) — persistant en prod, hors public/ et .output
# Recommandé en prod : /var/www/BourseFi/uploads
# Par défaut : {racine projet}/uploads
UPLOAD_DIR=""
